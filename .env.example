# ================================================================
# Seeed Tech Support Agent + SAG 配置示例
# 复制此文件为 .env 并填入你的 API Key
# ================================================================

# ── LLM（Qwen / OpenAI 兼容）─────────────────────────────────────
# Qwen: https://api.alibaba.com 或 https://dashscope.aliyuncs.com
# OpenAI: https://api.openai.com
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.alibaba.com/api/v1
OPENAI_LLM_MODEL=qwen3.7-plus

# ── SiliconFlow（Embedding + Rerank）────────────────────────────
SILICONFLOW_API_KEY=your_sf_key_here

# ── Qdrant 向量数据库 ──────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── SAG 配置 ───────────────────────────────────────────────────
SAG_BASE_URL=http://localhost:4173
SAG_ENABLED=true
SAG_PROJECT_ID=jetson_wiki
SAG_TOP_K=8
SAG_SEARCH_MODE=fast
SAG_STRATEGY=multi
SAG_QDRANT_WEIGHT=0.4
SAG_SAG_WEIGHT=0.6
