# ================================================================
# 生产环境配置模板
#
# 用法:
#   1. cp .env.production.template .env.production
#   2. 编辑 .env.production 填写真实密钥
#   3. .env.production 已加入 .gitignore，不会被提交
#
# 启动:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml \
#     --env-file .env.production up -d
# ================================================================

# ── LLM（必填，生产真 key） ──────────────────────────────────
LLM_API_KEY=sk-prod-your-real-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ── OpenAI 兼容（可选，给 tech-agent 用） ──────────────────────
OPENAI_API_KEY=sk-prod-your-real-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_LLM_MODEL=gpt-4o-mini

# ── Embedding（硅基流动 / 自托管） ─────────────────────────────
EMBEDDING_API_KEY=sk-prod-your-real-key-here

# ── 日志 ──────────────────────────────────────────────────────
LOG_LEVEL=INFO